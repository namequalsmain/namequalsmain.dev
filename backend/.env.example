# Copy to .env and fill real values. Never commit .env (it's gitignored).

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin credentials (bootstrap on startup).
# Password is hashed with bcrypt before storage.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-too

# --- Database ---
# SQLite file (relative to backend/). Use absolute path in production.
DATABASE_URL=sqlite+aiosqlite:///./portfolio.db

# --- CORS ---
# Comma-separated origins allowed to call the API.
# Example: https://namequalsmain.netlify.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=5242880   # 5 MB
