# Copy to .env and fill real values. Never commit .env (it's gitignored).

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin credentials (bootstrap on startup).
# Password is hashed with bcrypt before storage.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-too

# --- Database ---
# Local dev: SQLite (default below).
# Production: Postgres on Neon, e.g.
#   postgresql+asyncpg://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb
DATABASE_URL=sqlite+aiosqlite:///./portfolio.db

# --- CORS ---
# Comma-separated origins allowed to call the API.
# Example: https://namequalsmain.netlify.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Storage backend for uploaded images ---
# 'local' (dev)   — writes to UPLOAD_DIR, served by FastAPI at /uploads/...
# 'r2'   (prod)   — Cloudflare R2 object storage (S3-compatible)
STORAGE_BACKEND=local
MAX_UPLOAD_BYTES=5242880   # 5 MB

# --- Local storage settings (used when STORAGE_BACKEND=local) ---
UPLOAD_DIR=./uploads

# --- Cloudflare R2 (used when STORAGE_BACKEND=r2) ---
# Get from Cloudflare dashboard → R2 → API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=portfolio-uploads
# The public URL of the bucket. Either:
#   - Cloudflare-provided dev URL: https://pub-<hash>.r2.dev
#   - Or your custom domain bound to the bucket
R2_PUBLIC_BASE_URL=
